rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // O usuário pode criar/editar apenas dados básicos do perfil.
      // Campos de cobrança/acesso devem ser alterados somente pelas Netlify Functions com Firebase Admin.
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.keys().hasAny([
                      'accessUntil', 'freeTrialUsed', 'accessSource', 'plan', 'updatedAt'
                    ]);

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                      'accessUntil', 'freeTrialUsed', 'accessSource', 'plan', 'updatedAt'
                    ]);

      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /memories/{memoryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /diary/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /usage/{usageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /payments/{paymentId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }
  }
}
